rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'url', 'createdAt', 'status'])
        && data.userId is string
        && data.url is string
        && data.url.size() < 2048
        && data.status in ['pending', 'running', 'completed', 'failed'];
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'scanId', 'createdAt'])
        && data.userId is string
        && data.scanId is string;
    }

    function isValidUserDoc(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserDoc(request.resource.data);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /favorites/{favId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    match /scans/{scanId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isValidScan(request.resource.data);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isValidReport(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /shares/{shareId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'targetId', 'targetType', 'createdAt']);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /compareResults/{compareId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}